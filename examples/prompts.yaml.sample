# Copy to prompts.yaml and adjust to your needs.
# The 'model' key is only used by or-draw; gemini-draw always uses its built-in Gemini model.
# The 'prompt' value can be a text string or a path to a .txt file (relative to this YAML file).

images:
  - filename: "gemini/start.png"
    model: "google/gemini-2.0-flash-001"
    prompt: "Strichmännchen steht am Anfang eines Pfades."
    temperature: 0.1
    aspect_ratio: "16:9"

  - filename: "flux/detail.png"
    model: "black-forest-labs/flux-1-pro"
    prompt: "Nahaufnahme des Strichmännchens mit rotem Schal."

  - filename: "riverflow/action.png"
    model: "riverflow/riverflow-v2-pro"
    prompt: "descriptions/scene_2.txt"
    # reference_image: "ref/style.png"   # per-image reference (or-draw only)
