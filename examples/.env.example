# Google Gemini API key (required for gemini-draw)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model — override default (gemini-2.5-flash-preview-04-17)
# GEMINI_MODEL=gemini-2.5-flash-preview-04-17

# Optional: path to a custom system prompt file (overrides built-in SYSTEM_RULES)
# GEMINI_SYSTEM_PROMPT_FILE=examples/SYSTEM_PROMPT.md

# ── replicate-draw ────────────────────────────────────────────────────────────
# Replicate API token (required for replicate-draw)
REPLICATE_API_TOKEN=your_replicate_api_token_here

# Replicate model — override default (black-forest-labs/flux-2-pro)
# REPLICATE_MODEL=black-forest-labs/flux-2-pro

# Upscaler model — used when --width/--height are set and the image is too small
# REPLICATE_UPSCALER_MODEL=nightmareai/real-esrgan

# Optional: path to a custom system prompt file for replicate-draw
# REPLICATE_SYSTEM_PROMPT_FILE=examples/SYSTEM_PROMPT.md

# Optional: global reference images for style consistency (comma-separated paths)
# REPLICATE_REFERENCE_IMAGES=reference/style1.png,reference/style2.png
