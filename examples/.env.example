# Google Gemini API key (required for gemini-draw)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model — override default (gemini-2.5-flash-preview-04-17)
# GEMINI_MODEL=gemini-2.5-flash-preview-04-17

# Optional: path to a custom system prompt file (overrides built-in SYSTEM_RULES)
# GEMINI_SYSTEM_PROMPT_FILE=examples/SYSTEM_PROMPT.md

# OpenRouter API key (required for or-draw)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter model — override default (black-forest-labs/flux.2-pro)
# OR_MODEL=black-forest-labs/flux.2-pro
# OR_MODEL=black-forest-labs/flux-1-pro
# OR_MODEL=stabilityai/stable-diffusion-3.5-large

# Optional: path to a custom system prompt file for or-draw
# OR_SYSTEM_PROMPT_FILE=examples/SYSTEM_PROMPT.md
